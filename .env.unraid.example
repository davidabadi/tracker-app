# Container images published by .github/workflows/publish-images.yml.
# Use "latest" to follow main, or a release tag such as "v1.0.0".
TRACKER_VERSION=latest

APP_NAME=Tracker
APP_ENV=production
APP_KEY=base64:replace-with-a-generated-32-byte-key
APP_DEBUG=false
# Use the public HTTPS address when deploying behind a reverse proxy/tunnel.
APP_URL=http://192.168.1.50:8080

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info

WEB_PORT=8080

DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=tracker
DB_USERNAME=tracker
DB_PASSWORD=replace-with-a-long-random-password
# Keep PostgreSQL on persistent Unraid storage, not the Compose Manager folder.
DB_DATA_LOCATION=/mnt/user/appdata/tracker-app/postgres

SESSION_DRIVER=database
SESSION_LIFETIME=5256000
SESSION_EXPIRE_ON_CLOSE=false
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# Change to true when APP_URL uses HTTPS.
SESSION_SECURE_COOKIE=false

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Get a v3 API key from https://www.themoviedb.org/settings/api.
TMDB_API_KEY=replace-with-your-tmdb-v3-api-key

VITE_APP_NAME="${APP_NAME}"
