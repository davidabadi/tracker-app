APP_NAME=Tracker
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# When running behind the Cloudflare tunnel, set this to the public https URL.
APP_URL=http://localhost:8080

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# DB_HOST is the docker-compose service name "db" inside the network.
# For local (non-Docker) dev against Herd/local Postgres, use 127.0.0.1.
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=tracker
DB_USERNAME=tracker
DB_PASSWORD=change-me-in-env

# Enable or disable scheduled PostgreSQL dumps.
DB_DUMP_ENABLED=true
# Standard five-part cron expression interpreted in the application timezone.
DB_DUMP_CRON="0 2 * * *"
# Delete completed dumps older than this many days after a successful dump.
DB_DUMP_RETENTION_DAYS=7
# Host folder mounted into /backups/database in the app and scheduler containers.
DB_DUMP_PATH=./storage/app/backups/database

# Persistent login for the installed PWA: effectively non-expiring session
# (~10 years, in minutes). Session ends only on explicit logout. See spec §8.
SESSION_DRIVER=database
SESSION_LIFETIME=5256000
SESSION_EXPIRE_ON_CLOSE=false
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# TMDB metadata provider (spec §3). Get a v3 API key at
# https://www.themoviedb.org/settings/api
TMDB_API_KEY=your-tmdb-api-key-here

VITE_APP_NAME="${APP_NAME}"
